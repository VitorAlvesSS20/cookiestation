[
  {
    "origin": ["*"],
    "method": ["GET", "PUT", "POST", "DELETE", "HEAD", "OPTIONS"],
    "responseHeader": [
      "Content-Type",
      "Authorization",
      "Content-Length",
      "User-Agent",
      "x-goog-resumable",
      "x-firebase-storage-version",
      "x-firebase-gmpid",
      "x-requested-with",
      "If-Modified-Since",
      "Cache-Control",
      "Accept"
    ],
    "maxAgeSeconds": 3600
  }
]